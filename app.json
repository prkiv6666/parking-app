{
  "expo": {
    "name": "parking-app",
    "slug": "parking-app",
    "scheme": "parkradar",
    "plugins": [
      "expo-dev-client",
      "expo-notifications"
    ],
    "ios": {
      "bundleIdentifier": "app.parkradar.mobile",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Приложението използва локацията ти, за да маркира и показва свободни паркоместа наблизо.",
        "NSUserNotificationUsageDescription": "Park Radar използва известия, за да те уведоми за нови свободни места наблизо.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "app.parkradar.mobile",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "POST_NOTIFICATIONS"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "20c10969-43df-4fae-9cdf-7e18bf569eec"
      }
    }
  }
}
